# Copy to .env.local and fill in. .env.local is gitignored.

# ── Supabase (Phase 0/1) ───────────────────────────────────────────
# From Supabase dashboard → Project Settings → API.
# When these are set, the shop reads products from the database; until then
# it falls back to the in-repo sample catalogue.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (admin writes / never exposed to the browser):
SUPABASE_SERVICE_ROLE_KEY=

# ── ClearInvoice order hand-off (Phase 5) ──────────────────────────
# When set, placed orders POST to the ClearInvoice intake endpoint and become
# draft invoices. Until then, orders are accepted and logged only.
CLEARINVOICE_INTAKE_URL=
CLEARINVOICE_INTAKE_SECRET=

# ── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
